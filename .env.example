# ============================================================
#  ICAP — Конфигурация за машина с GPU 4-6GB VRAM / RAM 8GB
#  Модел: todorov/bggpt:Gemma-3-4B-IT-Q4_K_M
# ============================================================

# --- Ollama LLM -------------------------------------------
# За Docker: ползвайте http://host.docker.internal:11434/api/generate
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=todorov/bggpt:Gemma-3-4B-IT-Q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_URL=http://localhost:11434/api/embeddings

# Намален контекст — пести VRAM и RAM
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=256

# Слоеве на GPU. Стойността е както в работещата ти конфигурация.
OLLAMA_NUM_GPU=20

# Брой CPU нишки за частта извън GPU.
OLLAMA_NUM_THREAD=4

OLLAMA_TEMPERATURE=0.2
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.1
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=10m

# --- RAG / Qdrant ---------------------------------------
# (ICAP вече ползва Qdrant вместо ChromaDB за по-добра скорост)
# За Docker: ползвайте http://qdrant:6333
# ЗА WINDOWS (без Docker): Оставете празно за локално съхранение в папка qdrant_db
QDRANT_URL=

EMBEDDING_TYPE=local
RAG_CHUNK_SIZE=256
RAG_CHUNK_OVERLAP=32
RAG_TOP_K=3

# --- Industrial Connectivity ------------------------------
MQTT_BROKER=192.168.1.50
MQTT_PORT=1883
OPC_UA_SERVER_URL=opc.tcp://192.168.1.100:4840/

# --- API --------------------------------------------------
API_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000

# --- Security & CORS --------------------------------------
# Environment: development, staging, production
ICAP_ENVIRONMENT=development

# Allowed CORS origins (comma-separated). Use specific domains in production.
# Examples: http://localhost:3000,https://yourdomain.com
# WARNING: Using "*" allows all origins - avoid in production!
ICAP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# --- Edge / Lightweight Mode ------------------------------
ICAP_EDGE_MODE=1
ICAP_LIGHTWEIGHT=1

# --- Audit Trail ------------------------------------------
AUDIT_LOG_PATH=AuditTrail/measurements_log.csv

# --- Alerting & Push Notifications ------------------------
# Slack Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WEBHOOK_URL_HERE

# Email (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@yourcompany.com
SENDER_PASSWORD=your_app_password_here
RECIPIENT_EMAIL=admin@yourcompany.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+0987654321
