    {
      "name": "Color Analysis",
      "item": [
        {
          "name": "Analyze Color",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lab_sample\": [50.0, 2.0, 5.0],\n  \"lab_standard\": [50.0, 2.0, 5.0],\n  \"tolerance\": 1.0,\n  \"batch_id\": \"batch_123\",\n  \"operator_id\": \"test_operator\",\n  \"machine_id\": \"machine_1\",\n  \"client_id\": \"client_a\",\n  \"method\": \"CIE2000\",\n  \"illuminant\": \"D65\",\n  \"batch_size\": 1000\n}"
            },
            "url": {
              "raw": "{{base_url}}/color/analyze",
              "host": ["{{base_url}}"],
              "path": ["color", "analyze"]
            },
            "description": "Analyze color sample against standard"
          },
          "response": []
        },
        {
          "name": "Predict Trend",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batch_id\": \"batch_123\",\n  \"days_ahead\": 7\n}"
            },
            "url": {
              "raw": "{{base_url}}/color/predict_trend",
              "host": ["{{base_url}}"],
              "path": ["color", "predict_trend"]
            },
            "description": "Predict color trend for a batch"
          },
          "response": []
        }
      ]
    },
