          "response": []
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_role\": \"SUPERVISOR\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/users/test_user/role",
              "host": ["{{base_url}}"],
              "path": ["auth", "users", "test_user", "role"]
            },
            "description": "Update user role (requires user_management permission)"
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/users/test_user",
              "host": ["{{base_url}}"],
              "path": ["auth", "users", "test_user"]
            },
            "description": "Delete a user account (requires user_management permission)"
          },
          "response": []
        },
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/roles",
              "host": ["{{base_url}}"],
              "path": ["auth", "roles"]
            },
            "description": "List all available roles and their permissions"
          },
          "response": []
        }
      ]
